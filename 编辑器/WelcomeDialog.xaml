<Window x:Class="编辑器.WelcomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="欢迎使用 AI 写作助手" Height="440" Width="480"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="CanResize" SizeToContent="Height">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="欢迎使用 AI 写作助手" FontSize="18" FontWeight="Bold"
                   TextAlignment="Center" Margin="0,0,0,14"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="快速开始" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Margin="10,0,0,12" FontSize="13" LineHeight="20">
                    1. 点击「文件 → 新建项目」创建小说项目
                    &#x0a;2. 在左侧项目管理器中点击项目名，添加新章节
                    &#x0a;3. 在右侧 AI 面板中使用 AI 辅助写作
                </TextBlock>

                <TextBlock Text="AI 功能" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Margin="10,0,0,12" FontSize="13" LineHeight="20">
                    • 续写 — 基于当前内容继续写作
                    &#x0a;• 润色 — 美化文本，可开启风格预设
                    &#x0a;• 人名生成 — 生成适合小说风格的角色名字
                    &#x0a;• 万能聊天 — 自由对话生成任意内容
                </TextBlock>

                <TextBlock Text="API 配置" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Margin="10,0,0,12" FontSize="13" LineHeight="20">
                    使用 AI 功能前需先设置 API Key：
                    &#x0a;点击「AI助手 → API 设置」，选择提供商并填入 Key。
                    &#x0a;支持 OpenAI、DeepSeek、Claude、SiliconFlow 等。
                </TextBlock>

                <TextBlock Text="界面定制" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Margin="10,0,0,0" FontSize="13" LineHeight="20">
                    • 视图 → 外观设置：切换主题或设置背景图片
                    &#x0a;• 视图 → 路径设置：自定义文件存放位置
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <CheckBox x:Name="SkipWelcomeCheckBox" Grid.Row="2" Content="下次不再显示"
                  FontSize="13" Margin="0,0,0,12"/>

        <Button Grid.Row="3" Content="开始使用" Width="120" Height="32"
                HorizontalAlignment="Right" Click="OkButton_Click" IsDefault="True"/>
    </Grid>
</Window>

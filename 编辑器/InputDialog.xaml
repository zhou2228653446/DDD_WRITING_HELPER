<Window x:Class="编辑器.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Height="200" Width="450" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False" ResizeMode="CanResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageText" Grid.Row="0" Margin="0,0,0,10" TextWrapping="Wrap" FontSize="14"/>
        <TextBox x:Name="InputTextBox" Grid.Row="1" VerticalAlignment="Top" Margin="0,0,0,10" FontSize="14" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="80" Height="30" Margin="0,0,10,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Height="30" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>

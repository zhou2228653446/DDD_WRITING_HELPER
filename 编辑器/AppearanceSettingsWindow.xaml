<Window x:Class="编辑器.AppearanceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="外观设置" Height="420" Width="520"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="CanResize" SizeToContent="Height">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主题预设 -->
        <GroupBox Grid.Row="0" Header="主题预设" Margin="0,0,0,12" Padding="8">
            <ListBox x:Name="PresetListBox" Height="105"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     BorderThickness="0"
                     SelectionChanged="PresetListBox_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="8,6" Margin="0,0,0,4"
                                CornerRadius="6" BorderThickness="1" BorderBrush="#E0E0E0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 色块预览 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal"
                                            Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Border Width="22" Height="22" CornerRadius="3"
                                            BorderBrush="#AAA" BorderThickness="0.5"
                                            Background="{Binding PanelBgBrush}"
                                            ToolTip="面板底色"/>
                                    <Border Width="22" Height="22" CornerRadius="3" Margin="4,0,0,0"
                                            BorderBrush="#AAA" BorderThickness="0.5"
                                            Background="{Binding EditorBgBrush}"
                                            ToolTip="编辑区背景"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#888"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>

        <!-- 自定义背景图片 -->
        <GroupBox Grid.Row="1" Header="自定义背景图片" Margin="0,0,0,12" Padding="8">
            <StackPanel>
                <CheckBox x:Name="EnableBgCheckBox" Content="启用自定义图片作为窗口背景"
                          FontSize="13" Margin="0,0,0,8"
                          Checked="EnableBg_Changed" Unchecked="EnableBg_Changed"/>
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BgPathTextBox" Grid.Column="0"
                             FontSize="12" Padding="4" IsReadOnly="True"
                             Background="#F5F5F5"/>
                    <Button Grid.Column="1" x:Name="BrowseBgBtn" Content="浏览..."
                            Width="70" Margin="6,0,0,0" Padding="4,2"
                            Click="BrowseBg_Click"/>
                </Grid>
                <Button x:Name="RemoveBgBtn" Content="移除背景图片" Padding="8,3"
                        FontSize="12" IsEnabled="False"
                        Click="RemoveBg_Click"/>
                <TextBlock Text="注意：编辑区域将保持浅色背景以保证可读性"
                           FontSize="11" Foreground="#999" Margin="0,6,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- 提示 -->
        <Border Grid.Row="2" Background="#FFF8E1" CornerRadius="4" Padding="10" Margin="0,0,0,12"
                BorderBrush="#FFE082" BorderThickness="1">
            <TextBlock Text="背景图片仅作为窗口氛围装饰，不会影响编辑区可读性。您随时可以切换回纯色主题。"
                       TextWrapping="Wrap" FontSize="12"/>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="确定" Width="80" Height="32" Margin="0,0,10,0"
                    Click="OkButton_Click" IsDefault="True"/>
            <Button Content="取消" Width="80" Height="32" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
